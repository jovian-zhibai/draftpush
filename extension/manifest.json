{
  "manifest_version": 3,
  "name": "草稿推送 DraftPush",
  "version": "0.1.0",
  "description": "AI Skill 写完内容，一键同步到小红书、公众号、抖音草稿箱",
  "permissions": [
    "nativeMessaging",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://creator.xiaohongshu.com/*",
    "https://edith.xiaohongshu.com/*",
    "https://www.xiaohongshu.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://creator.xiaohongshu.com/*"],
      "js": ["content-scripts/xiaohongshu.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}