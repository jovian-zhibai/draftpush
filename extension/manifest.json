{
  "manifest_version": 3,
  "name": "草稿推送 DraftPush",
  "version": "0.3.0",
  "description": "AI Skill 写完内容，一键同步到小红书、公众号、抖音草稿箱",
  "permissions": [
    "nativeMessaging",
    "storage",
    "notifications",
    "cookies",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://creator.xiaohongshu.com/*",
    "https://edith.xiaohongshu.com/*",
    "https://www.xiaohongshu.com/*",
    "https://ros-upload.xiaohongshu.com/*",
    "https://creator.douyin.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://creator.xiaohongshu.com/*"],
      "js": ["content-scripts/xiaohongshu.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://creator.douyin.com/*"],
      "js": ["content-scripts/douyin.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
